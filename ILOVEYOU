// ── STATE ──
let userAnswers = {};
let submitted = false;

// ── RENDER QUIZ ──
function renderQuiz() {
  const area = document.getElementById('quizArea');
  let html = '';

  QUESTIONS.forEach((q, idx) => {
    html += `<div class="q-card" id="qcard-${q.id}">`;
    html += `<div class="q-num">Question ${q.id} <span class="q-topic">${q.topic}</span></div>`;
    html += `<p class="q-text">${q.text}</p>`;

    // Table if present
    if (q.table) {
      html += '<table class="q-table"><tr>';
      q.table.headers.forEach(h => html += `<th>${h}</th>`);
      html += '</tr>';
      q.table.rows.forEach(row => {
        html += '<tr>';
        row.forEach(cell => html += `<td>${cell}</td>`);
        html += '</tr>';
      });
      html += '</table>';
    }

    // Graph placeholder
    if (q.hasGraph) {
      html += `<div class="graph-box" id="graph-${q.id}"></div>`;
    }

    // Options
    html += `<ul class="options-list" id="opts-${q.id}">`;
    q.opts.forEach((opt, oi) => {
      html += `<li onclick="selectAnswer(${q.id}, ${oi}, this)" id="opt-${q.id}-${oi}">${opt}</li>`;
    });
    html += '</ul>';

    // Explanation (hidden until review)
    html += `<div class="explanation" id="exp-${q.id}"></div>`;
    html += '</div>';
  });

  // Submit button
  html += `<div class="btn-wrap" id="submitWrap">
    <button class="btn btn-submit" id="submitBtn" onclick="submitQuiz()">
      🐱 Submit Quiz — Let's See How You Did! 🐈
    </button>
    <p style="color:#ad1457; font-size:0.85em; margin-top:8px;" id="submitHint">Answer all 35 questions first!</p>
  </div>`;

  // Results banner (hidden)
  html += `<div class="results-banner" id="resultsBanner"></div>`;

  area.innerHTML = html;
  drawGraphs();
}

// ── SELECT ANSWER ──
function selectAnswer(qid, optIdx, el) {
  if (submitted) return;
  userAnswers[qid] = optIdx;

  // Update visual
  const opts = document.querySelectorAll(`#opts-${qid} li`);
  opts.forEach(li => li.classList.remove('selected'));
  el.classList.add('selected');

  // Update card border
  document.getElementById(`qcard-${qid}`).classList.add('answered');

  updateProgress();
}

// ── PROGRESS ──
function updateProgress() {
  const count = Object.keys(userAnswers).length;
  const pct = (count / 35) * 100;
  document.getElementById('progressFill').style.width = pct + '%';
  document.getElementById('progressText').textContent = `${count} of 35 answered`;

  const hint = document.getElementById('submitHint');
  if (count === 35) {
    hint.textContent = "All done! Hit submit whenever you're ready!";
    hint.style.color = '#2e7d32';
  } else {
    hint.textContent = `${35 - count} questions remaining`;
    hint.style.color = '#ad1457';
  }
}

// ── SUBMIT ──
function submitQuiz() {
  const unanswered = 35 - Object.keys(userAnswers).length;
  if (unanswered > 0) {
    if (!confirm(`You still have ${unanswered} unanswered question(s). Submit anyway? (Unanswered = wrong)`)) return;
  }

  submitted = true;

  let correct = 0;
  let wrongIds = [];

  QUESTIONS.forEach(q => {
    const userAns = userAnswers[q.id];
    const isCorrect = userAns === q.answer;
    if (isCorrect) correct++;
    else wrongIds.push(q.id);

    const card = document.getElementById(`qcard-${q.id}`);
    card.classList.remove('answered');
    card.classList.add(isCorrect ? 'review-correct' : 'review-wrong');

    // Style options
    const opts = document.querySelectorAll(`#opts-${q.id} li`);
    opts.forEach((li, oi) => {
      li.onclick = null;
      li.style.cursor = 'default';
      if (oi === q.answer && isCorrect) {
        li.className = 'r-correct';
      } else if (oi === userAns && !isCorrect) {
        li.className = 'r-wrong';
      } else if (oi === q.answer && !isCorrect) {
        li.className = 'r-right-answer';
      } else {
        li.className = 'r-neutral';
      }
    });

    // Show explanation
    const expDiv = document.getElementById(`exp-${q.id}`);
    expDiv.classList.add('show', isCorrect ? 'exp-correct' : 'exp-wrong');
    if (isCorrect) {
      expDiv.innerHTML = `<strong>✓ Correct!</strong> ${q.explain}<div class="cat-msg">${q.catMsg}</div>`;
    } else {
      expDiv.innerHTML = `<strong>✗ Not quite!</strong> ${q.explain}<div class="cat-msg">${q.catMsg}</div>`;
    }
  });

  // Hide submit button
  document.getElementById('submitWrap').style.display = 'none';

  // Show results banner
  const pct = Math.round((correct/35)*100);
  let grade, celebration;
  if (pct >= 90) { grade = "Pie Cookie and Niko are SO proud of you! You're crushing it!"; celebration = "🐱🎉🐈✨🌟"; }
  else if (pct >= 80) { grade = "Great job, Cecelia! Almost perfect — just a few to review!"; celebration = "🐱👏🐈💪"; }
  else if (pct >= 70) { grade = "Solid work! Review the red ones below and you'll ace the real test!"; celebration = "🐱📖🐈💡"; }
  else if (pct >= 60) { grade = "Good start! The cats believe in you — focus on the explanations below!"; celebration = "🐱❤️🐈📚"; }
  else { grade = "Don't worry! Every wrong answer is a learning moment. Pie Cookie and Niko are here to help!"; celebration = "🐱🤗🐈💕"; }

  const banner = document.getElementById('resultsBanner');
  banner.classList.add('show');
  banner.innerHTML = `
    <div class="cat-celebration">${celebration}</div>
    <div class="big-score">${correct}/35</div>
    <div class="score-label">${pct}% — ${correct} correct, ${35-correct} to review</div>
    <div class="grade-msg">${grade}</div>
    ${wrongIds.length > 0 ? `
    <div class="results-nav" style="margin-top:16px;">
      <p style="font-size:0.85em; color:#ad1457; width:100%; margin-bottom:6px;">Jump to missed questions:</p>
      ${wrongIds.map(id => `<button class="btn-scroll" onclick="document.getElementById('qcard-${id}').scrollIntoView({behavior:'smooth',block:'center'})">Q${id}</button>`).join('')}
    </div>` : ''}
    <div style="margin-top:20px;">
      <button class="btn btn-retake" onclick="location.reload()">🔄 Retake Quiz</button>
    </div>
  `;
  banner.scrollIntoView({ behavior: 'smooth' });

  // Update progress bar
  document.getElementById('progressFill').style.width = '100%';
  document.getElementById('progressFill').style.background = pct >= 80 ? 'linear-gradient(90deg, #66bb6a, #43a047)' : 'linear-gradient(90deg, #ffa726, #ef5350)';
  document.getElementById('progressText').textContent = `Score: ${correct}/35 (${pct}%)`;
}

