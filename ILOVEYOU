{
  id:3, topic:"Utility",
  text:"The following table shows total and marginal utilities for hotdogs. What is John's marginal utility from the 4th hotdog?",
  table:{headers:["Qty","Total Utility","Marginal Utility"],rows:[["0","0","—"],["1","5","5"],["2","?","2"],["3","?","1"],["4","8","?"],["5","7","−1"]]},
  opts:["-1","0","8","4"],
