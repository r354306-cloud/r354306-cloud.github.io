<title>Cecelia's Econ Study Quiz</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; background: #fdf6f0; color: #3d2c2c; line-height: 1.65; }

  /* ── HEADER ── */
  .header { background: linear-gradient(135deg, #fce4ec 0%, #f3e5f5 50%, #e8eaf6 100%); padding: 36px 20px 28px; text-align: center; border-bottom: 3px solid #f48fb1; position: relative; overflow: hidden; }
  .header h1 { font-size: 2em; color: #ad1457; margin-bottom: 4px; }
  .header .subtitle { color: #6a1b9a; font-size: 1.05em; }
  .cat-row { display: flex; justify-content: center; gap: 18px; margin-top: 14px; font-size: 1.6em; }
  .cat-row span { animation: catBounce 1.5s ease-in-out infinite; }
  .cat-row span:nth-child(2) { animation-delay: 0.3s; }
  .cat-row span:nth-child(3) { animation-delay: 0.6s; }
  @keyframes catBounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }

  /* ── PROGRESS BAR ── */
  .progress-wrap { position: sticky; top: 0; z-index: 100; background: #fdf6f0; padding: 10px 20px; border-bottom: 1px solid #f8bbd0; }
  .progress-bar-bg { height: 12px; background: #fce4ec; border-radius: 10px; overflow: hidden; }
  .progress-bar-fill { height: 100%; background: linear-gradient(90deg, #f48fb1, #ce93d8, #9fa8da); border-radius: 10px; transition: width 0.4s ease; width: 0%; }
  .progress-text { font-size: 0.82em; color: #ad1457; margin-top: 4px; text-align: center; }

  /* ── CONTAINER ── */
  .container { max-width: 780px; margin: 0 auto; padding: 20px; }

  /* ── QUESTION CARD ── */
  .q-card { background: #fff; border-radius: 14px; margin-bottom: 18px; padding: 22px 24px; border: 2px solid #f8bbd0; box-shadow: 0 2px 8px rgba(173,20,87,0.06); transition: border-color 0.3s; }
  .q-card.answered { border-color: #ce93d8; }
  .q-card.review-correct { border-left: 5px solid #66bb6a; }
  .q-card.review-wrong { border-left: 5px solid #ef5350; }
  .q-num { font-size: 0.8em; font-weight: 700; color: #ad1457; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; }
  .q-topic { display: inline-block; background: #f3e5f5; color: #7b1fa2; padding: 2px 10px; border-radius: 12px; font-size: 0.72em; font-weight: 600; margin-left: 8px; }
  .q-text { font-size: 1.02em; margin-bottom: 14px; color: #37474f; }

  /* ── TABLE ── */
  .q-table { width: 100%; border-collapse: collapse; margin: 12px 0; font-size: 0.88em; }
  .q-table th { background: #fce4ec; color: #ad1457; padding: 8px 10px; text-align: center; font-size: 0.85em; }
  .q-table td { padding: 6px 10px; text-align: center; border-bottom: 1px solid #fce4ec; }

  /* ── OPTIONS ── */
  .options-list { list-style: none; }
  .options-list li { padding: 11px 16px; margin-bottom: 7px; border-radius: 10px; border: 2px solid #f0e0e6; background: #fffbfc; cursor: pointer; transition: all 0.2s; font-size: 0.95em; }
  .options-list li:hover { border-color: #f48fb1; background: #fce4ec; }
  .options-list li.selected { border-color: #ab47bc; background: #f3e5f5; font-weight: 600; }
  .options-list li.selected::before { content: ""; display: inline-block; width: 10px; height: 10px; background: #ab47bc; border-radius: 50%; margin-right: 10px; }

  /* Review mode styles */
  .options-list li.r-correct { border-color: #66bb6a; background: #e8f5e9; cursor: default; }
  .options-list li.r-correct::before { content: "✓ "; color: #2e7d32; font-weight: bold; }
  .options-list li.r-wrong { border-color: #ef5350; background: #ffebee; text-decoration: line-through; opacity: 0.7; cursor: default; }
  .options-list li.r-wrong::before { content: "✗ "; color: #c62828; font-weight: bold; }
  .options-list li.r-right-answer { border-color: #66bb6a; background: #e8f5e9; cursor: default; }
  .options-list li.r-right-answer::before { content: "→ "; color: #2e7d32; font-weight: bold; }
  .options-list li.r-neutral { cursor: default; opacity: 0.55; }
  .options-list li.r-neutral:hover { border-color: #f0e0e6; background: #fffbfc; }

  /* ── EXPLANATION (hidden during quiz) ── */
  .explanation { display: none; margin-top: 14px; padding: 14px 16px; border-radius: 10px; font-size: 0.9em; line-height: 1.6; }
  .explanation.show { display: block; }
  .explanation.exp-correct { background: #e8f5e9; border-left: 4px solid #66bb6a; color: #2e7d32; }
  .explanation.exp-wrong { background: #fff3e0; border-left: 4px solid #ffa726; color: #e65100; }
  .explanation strong { color: inherit; }
  .cat-msg { margin-top: 10px; padding: 8px 14px; background: rgba(255,255,255,0.7); border-radius: 8px; font-style: italic; font-size: 0.9em; }

  /* ── GRAPH CONTAINERS ── */
  .graph-box { margin: 14px 0; background: #fafafa; border-radius: 10px; padding: 14px; border: 1px solid #f0e0e6; }
  .graph-box canvas { max-height: 240px; }
  .svg-graph { width: 100%; max-width: 380px; margin: 8px auto; display: block; }

  /* ── BUTTONS ── */
  .btn-wrap { text-align: center; margin: 30px 0; }
  .btn { padding: 14px 40px; font-size: 1.1em; font-weight: 700; border: none; border-radius: 30px; cursor: pointer; transition: all 0.3s; }
  .btn-submit { background: linear-gradient(135deg, #ec407a, #ab47bc); color: white; box-shadow: 0 4px 15px rgba(236,64,122,0.3); }
  .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(236,64,122,0.4); }
  .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .btn-retake { background: linear-gradient(135deg, #42a5f5, #ab47bc); color: white; box-shadow: 0 4px 15px rgba(66,165,245,0.3); }
  .btn-retake:hover { transform: translateY(-2px); }
  .btn-scroll { background: #f48fb1; color: white; padding: 10px 24px; font-size: 0.9em; border-radius: 20px; border: none; cursor: pointer; margin: 4px; }

  /* ── RESULTS BANNER ── */
  .results-banner { display: none; text-align: center; padding: 30px 20px; background: linear-gradient(135deg, #fce4ec, #f3e5f5); border-radius: 16px; margin: 20px 0; border: 2px solid #f48fb1; }
  .results-banner.show { display: block; }
  .results-banner .big-score { font-size: 3.5em; font-weight: 800; color: #ad1457; }
  .results-banner .score-label { font-size: 1.1em; color: #6a1b9a; }
  .results-banner .cat-celebration { font-size: 2em; margin: 12px 0; }
  .results-banner .grade-msg { font-size: 1.15em; margin-top: 8px; color: #37474f; }
  .results-nav { display: flex; justify-content: center; gap: 8px; margin-top: 14px; flex-wrap: wrap; }

  .hidden { display: none; }
  @media (max-width: 600px) { .header h1 { font-size: 1.5em; } .container { padding: 12px; } .q-card { padding: 16px; } }
</style>
